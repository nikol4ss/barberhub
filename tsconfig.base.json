{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo",
    "baseUrl": ".",

    "paths": {
      "@barberhub/types/*": ["packages/types/src/*"],
      "@barberhub/*": ["packages/*/src"]
    }
  },

  "include": ["client/src", "server/src", "packages/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
